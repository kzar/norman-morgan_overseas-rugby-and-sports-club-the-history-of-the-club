		<dc:title id="title">Overseas Rugby and Sports Club - The History of the Club</dc:title>
		<meta property="file-as" refines="#title">Overseas Rugby and Sports Club - The History of the Club</meta>
		<dc:subject id="subject-1">Rugby football -- Clubs</dc:subject>
		<dc:subject id="subject-2">Rugby football -- History</dc:subject>
		<dc:subject id="subject-3">Malta -- History</dc:subject>
		<dc:subject id="subject-4">Great Britain -- History, Military -- 20th century</dc:subject>
		<meta property="authority" refines="#subject-1">LCSH</meta>
		<meta property="term" refines="#subject-1">sh85115743</meta>
		<meta property="authority" refines="#subject-2">LCSH</meta>

#!/usr/bin/env python3
"""Build the ebook.

Based on the Standard Ebooks tooling:
- https://github.com/standardebooks/tools
- https://github.com/standardebooks/web/blob/master/scripts/deploy-ebook-to-www
"""

from __future__ import annotations

import argparse
import html
import re
import shlex
import shutil
import subprocess
import tempfile
import xml.etree.ElementTree as ET
from dataclasses import dataclass
from pathlib import Path


OPF_NS = {
    "opf": "http://www.idpf.org/2007/opf",
    "dc": "http://purl.org/dc/elements/1.1/",
}

TEMPLATE_TOKEN_RE = re.compile(r"{{\s*([A-Z0-9_]+)\s*}}")

TITLE_RE = re.compile(r"<title>(.*?)</title>", re.DOTALL)
BODY_RE = re.compile(r"<body([^>]*)>", re.DOTALL)
MAIN_TAG_RE = re.compile(r"<main\b")


@dataclass(frozen=True)
class BookMetadata:
    work_title: str
    author: str
    language: str
    book_description: str
    book_url: str | None
    github_url: str | None
    spine_text_files: list[str]


def info(message: str) -> None:
    print(message, flush=True)


def run_command(command: list[str], cwd: Path, description: str) -> None:
    info(description)
    subprocess.run(command, cwd=str(cwd), check=True)


def first_text(root: ET.Element, *xpaths: str, default: str = "") -> str:
    for xpath in xpaths:
        value = root.findtext(xpath, namespaces=OPF_NS)
        if value and value.strip():
            return value.strip()
    return default


def parse_book_metadata(source_dir: Path) -> BookMetadata:
    content_opf = source_dir / "src" / "epub" / "content.opf"
    tree = ET.parse(content_opf)
    root = tree.getroot()

    work_title = first_text(root, ".//dc:title[@id='title']", ".//dc:title", default="Untitled")
    author = first_text(root, ".//dc:creator[@id='author']", ".//dc:creator", default="Unknown")
    language = first_text(root, ".//dc:language", default="en")
    book_description = first_text(
        root,
        ".//opf:meta[@property='se:long-description']",
        ".//dc:description",
        default="Description coming soon.",
    )
    github_url = first_text(root, ".//opf:meta[@property='se:url.vcs.github']") or None
    raw_identifier = first_text(root, ".//dc:identifier[@id='uid']", ".//dc:identifier")
    book_url = raw_identifier.rstrip("/") if raw_identifier.startswith(("http://", "https://")) else None

    manifest_by_id: dict[str, str] = {}
    for item in root.findall(".//opf:manifest/opf:item", OPF_NS):
        item_id = item.get("id")
        href = item.get("href")
        if item_id and href:
            manifest_by_id[item_id] = href

    spine_text_files: list[str] = []
    for item_ref in root.findall(".//opf:spine/opf:itemref", OPF_NS):
        item_id = item_ref.get("idref")
        if not item_id:
            continue
        href = manifest_by_id.get(item_id)
        if not href:
            continue
        if href.startswith("text/") and href.endswith(".xhtml"):
            spine_text_files.append(Path(href).name)

    return BookMetadata(
        work_title=work_title,
        author=author,
        language=language,
        book_description=book_description,
        book_url=book_url,
        github_url=github_url,
        spine_text_files=spine_text_files,
    )


def slugify(value: str) -> str:
    slug = re.sub(r"[^a-z0-9]+", "-", value.lower()).strip("-")
    return slug or "book"


def rename_ebook_files(downloads_dir: Path, metadata: BookMetadata) -> str:
    author_slug = slugify(metadata.author)
    target_prefix = f"{author_slug}_"
    renamed = 0
    for source_path in sorted(downloads_dir.glob("*_ebooks_*")):
        if not source_path.is_file():
            continue

        _, separator, suffix = source_path.name.partition("_ebooks_")
        if not separator:
            continue

        target_name = f"{target_prefix}{suffix}"
        target_path = downloads_dir / target_name
        if target_path.exists():
            target_path.unlink()
        source_path.rename(target_path)
        renamed += 1

    if renamed == 0:
        raise RuntimeError("No ebook files matching '*_ebooks_*' were produced.")

    epub_bases = [
        path.name.removesuffix(".epub")
        for path in sorted(downloads_dir.glob(f"{author_slug}_*.epub"))
        if path.is_file() and not path.name.endswith((".kepub.epub", "_advanced.epub"))
    ]
    if len(epub_bases) != 1:
        raise RuntimeError("Could not infer exactly one compatible .epub filename after renaming.")

    return epub_bases[0]


def recent_commits(source_dir: Path, limit: int) -> list[tuple[str, str, str]]:
    try:
        output = subprocess.check_output(
            [
                "git",
                "-C",
                str(source_dir),
                "log",
                f"--max-count={limit}",
                "--date=format:%b %e, %Y",
                "--pretty=format:%cd%x1f%H%x1f%s",
            ],
            text=True,
        )
    except subprocess.CalledProcessError as error:
        raise RuntimeError("Unable to read git history for recent changes section.") from error

    commits: list[tuple[str, str, str]] = []
    for line in output.splitlines():
        if not line.strip():
            continue
        parts = line.split("\x1f", 2)
        if len(parts) != 3:
            continue
        commit_date, commit_hash, commit_subject = parts
        commits.append((" ".join(commit_date.split()), commit_hash, commit_subject))

    return commits


def render_landing_page(
    landing_page_path: Path,
    *,
    metadata: BookMetadata,
    source_dir: Path,
    download_file_basename: str,
) -> None:
    commits = recent_commits(source_dir, limit=5)
    github_url = metadata.github_url or "https://github.com/standardebooks/tools"
    commit_url_prefix = (
        f'{html.escape(metadata.github_url, quote=True)}/commit/' if metadata.github_url else None
    )
    recent_changes_items = "\n".join(
        (
            f"<li>{html.escape(commit_date)} - "
            f'<a href="{commit_url_prefix}{commit_hash}">{html.escape(commit_subject)}</a></li>'
        )
        if commit_url_prefix
        else f"<li>{html.escape(commit_date)} - {html.escape(commit_subject)}</li>"
        for commit_date, commit_hash, commit_subject in commits
    ) or "<li>No recent commits found.</li>"

    template = landing_page_path.read_text(encoding="utf-8")
    rendered = template
    for key, value in {
        "BOOK_LANGUAGE": html.escape(metadata.language),
        "BOOK_TITLE": html.escape(metadata.work_title),
        "BOOK_AUTHOR": html.escape(metadata.author),
        "META_DESCRIPTION": html.escape(
            f"Read and download {metadata.work_title} by {metadata.author}.",
            quote=True,
        ),
        "BOOK_DESCRIPTION": html.unescape(metadata.book_description),
        "DOWNLOAD_FILE_BASENAME": html.escape(download_file_basename, quote=True),
        "RECENT_CHANGES_ITEMS": recent_changes_items,
        "GITHUB_REPO_URL": html.escape(github_url, quote=True),
    }.items():
        rendered = rendered.replace(f"{{{{ {key} }}}}", value)

    unresolved = sorted(set(TEMPLATE_TOKEN_RE.findall(rendered)))
    if unresolved:
        raise RuntimeError(f"Unresolved template token(s): {', '.join(unresolved)}")

    landing_page_path.write_text(rendered, encoding="utf-8")


def strip_epub_css_properties(css_file: Path) -> None:
    css = css_file.read_text(encoding="utf-8")
    css = re.sub(r"\s*-epub-[^;]+?;", "", css)
    css_file.write_text(css, encoding="utf-8")


def prefix_title(xhtml: str, work_title: str) -> str:
    match = TITLE_RE.search(xhtml)
    if not match:
        return xhtml

    current_title = match.group(1)
    wanted_prefix = f"{work_title} - "
    if current_title.startswith(wanted_prefix):
        return xhtml

    return f"{xhtml[:match.start(1)]}{wanted_prefix}{current_title}{xhtml[match.end(1):]}"


def ensure_lang_attribute(xhtml: str) -> str:
    html_tag_match = re.search(r"<html\b[^>]*>", xhtml)
    if not html_tag_match:
        return xhtml

    html_tag = html_tag_match.group(0)
    if 'xml:lang="' not in html_tag:
        return xhtml
    if re.search(r'(^|\s)lang="[^"]+"', html_tag):
        return xhtml

    updated_tag = re.sub(r'xml:lang="([^"]+)"', r'xml:lang="\1" lang="\1"', html_tag, count=1)
    return f"{xhtml[:html_tag_match.start()]}{updated_tag}{xhtml[html_tag_match.end():]}"


def ensure_main_wrapper(xhtml: str) -> str:
    if not MAIN_TAG_RE.search(xhtml):
        xhtml = BODY_RE.sub(r"<body\1><main>", xhtml, count=1)
        xhtml = xhtml.replace("</body>", "</main></body>", 1)
    return xhtml


def ensure_header(xhtml: str, header_html: str) -> str:
    return BODY_RE.sub(rf"<body\1>{header_html}", xhtml, count=1)


def insert_head_elements(
    xhtml: str,
    *,
    css_hrefs: list[str] | None,
    canonical_url: str | None,
    favicon_prefix: str | None = None,
) -> str:
    if "</title>" not in xhtml:
        return xhtml

    insertions: list[str] = []
    if css_hrefs:
        insertions.extend(
            f'<link href="{css_href}" media="screen" rel="stylesheet" type="text/css"/>'
            for css_href in css_hrefs
        )
    if canonical_url:
        insertions.append(f'<link rel="canonical" href="{canonical_url}" />')
    if favicon_prefix:
        insertions.extend(
            [
                f'<link rel="shortcut icon" type="image/x-icon" href="{favicon_prefix}favicon.ico"/>',
                f'<link rel="icon" type="image/webp" sizes="16x16" href="{favicon_prefix}favicon-16x16.webp"/>',
                f'<link rel="icon" type="image/webp" sizes="32x32" href="{favicon_prefix}favicon-32x32.webp"/>',
                f'<link rel="icon" type="image/webp" sizes="96x96" href="{favicon_prefix}favicon-96x96.webp"/>',
            ]
        )
    insertions.append('<meta content="width=device-width, initial-scale=1" name="viewport"/>')

    joined = "\n\t\t".join(insertions)
    return xhtml.replace("</title>", f"</title>\n\t\t{joined}", 1)


def adjust_colophon_links(xhtml: str) -> str:
    return xhtml.replace('<p><a href="http', '<p><a rel="nofollow" href="http')


def rewrite_toc_links(xhtml: str) -> str:
    return re.sub(r'href="text/([^"]+)"', r'href="\1"', xhtml)


def extract_page_title(xhtml: str, work_title: str) -> str:
    match = TITLE_RE.search(xhtml)
    if not match:
        return ""

    title = html.unescape(re.sub(r"<[^>]+>", "", match.group(1)).strip())
    prefix = f"{work_title} - "
    if title.startswith(prefix):
        return title[len(prefix) :]
    return title


def inject_footer(xhtml: str, previous_link: str, next_link: str) -> str:
    footer = f"<footer><ul><li>{previous_link}</li><li>{next_link}</li></ul></footer>"
    return xhtml.replace("</body>", f"{footer}</body>", 1)


def canonical_for_text_file(book_url: str | None, filename: str) -> str | None:
    if not book_url:
        return None

    if filename == "index.xhtml":
        return f"{book_url}/text"
    if filename == "toc.xhtml":
        return f"{book_url}/text/toc.xhtml"
    return f"{book_url}/text/{Path(filename).stem}"


def create_chapter_footers(text_dir: Path, metadata: BookMetadata) -> None:
    spine_files = [name for name in metadata.spine_text_files if (text_dir / name).is_file()]
    if not spine_files:
        return

    titles: dict[str, str] = {}
    for filename in spine_files:
        page = (text_dir / filename).read_text(encoding="utf-8")
        titles[filename] = extract_page_title(page, metadata.work_title)

    for index, filename in enumerate(spine_files):
        previous_file = spine_files[index - 1] if index > 0 else None
        next_file = spine_files[index + 1] if index < len(spine_files) - 1 else None

        previous_link = (
            f'<a href="{previous_file}" rel="prev"><i>Previous:</i> {html.escape(titles[previous_file])}</a>'
            if previous_file
            else ""
        )
        next_link = (
            f'<a href="{next_file}" rel="next"><i>Next:</i> {html.escape(titles[next_file])}</a>'
            if next_file
            else ""
        )

        page_path = text_dir / filename
        page = page_path.read_text(encoding="utf-8")
        page = inject_footer(page, previous_link=previous_link, next_link=next_link)
        page_path.write_text(page, encoding="utf-8")


def transform_page(
    page_path: Path,
    metadata: BookMetadata,
    *,
    header_html: str,
    css_hrefs: list[str] | None,
    canonical_url: str | None,
    favicon_prefix: str | None,
    rewrite_toc: bool = False,
    add_title_prefix: bool = True,
    adjust_colophon: bool = False,
) -> None:
    page = page_path.read_text(encoding="utf-8")
    if rewrite_toc:
        page = rewrite_toc_links(page)
    page = ensure_lang_attribute(page)
    if add_title_prefix:
        page = prefix_title(page, metadata.work_title)
    page = ensure_main_wrapper(page)
    page = ensure_header(page, header_html)
    page = insert_head_elements(
        page,
        css_hrefs=css_hrefs,
        canonical_url=canonical_url,
        favicon_prefix=favicon_prefix,
    )
    if adjust_colophon:
        page = adjust_colophon_links(page)
    page_path.write_text(page, encoding="utf-8")


def build_text_output(
    source_dir: Path,
    staging_dir: Path,
    metadata: BookMetadata,
    web_css: Path,
    web_local_css: Path,
) -> None:
    src_epub = source_dir / "src" / "epub"

    shutil.copytree(src_epub / "css", staging_dir / "css")
    shutil.copytree(src_epub / "images", staging_dir / "images")
    shutil.copytree(src_epub / "text", staging_dir / "text")

    shutil.copy2(src_epub / "toc.xhtml", staging_dir / "text" / "toc.xhtml")
    shutil.copy2(src_epub / "toc.xhtml", staging_dir / "text" / "index.xhtml")

    for css_file in (staging_dir / "css").glob("*.css"):
        strip_epub_css_properties(css_file)

    shutil.copy2(web_css, staging_dir / "css" / "web.css")
    shutil.copy2(web_local_css, staging_dir / "css" / "web-local.css")

    single_page_path = staging_dir / "text" / "single-page" / "index.xhtml"
    single_page_path.parent.mkdir(parents=True, exist_ok=True)
    combined_web_css = staging_dir / "css" / "web-single-page.css"
    combined_web_css.write_text(
        f"{web_css.read_text(encoding='utf-8')}\n\n{web_local_css.read_text(encoding='utf-8')}\n",
        encoding="utf-8",
    )

    run_command(
        [
            "se",
            "recompose-epub",
            "--xhtml",
            "--output",
            str(single_page_path),
            "--extra-css-file",
            str(combined_web_css),
            str(source_dir),
        ],
        cwd=source_dir,
        description="Generating single-page web view...",
    )

    text_header_html = (
        '<header><nav><ul>'
        '<li><a href="../">Back to ebook</a></li>'
        '<li><a href="index.xhtml">Table of contents</a></li>'
        "</ul></nav></header>"
    )
    for path in sorted((staging_dir / "text").glob("*.xhtml")):
        transform_page(
            path,
            metadata,
            header_html=text_header_html,
            css_hrefs=["../css/web.css", "../css/web-local.css"],
            canonical_url=canonical_for_text_file(metadata.book_url, path.name),
            favicon_prefix="../",
            rewrite_toc=path.name in {"toc.xhtml", "index.xhtml"},
            add_title_prefix=True,
            adjust_colophon=path.name == "colophon.xhtml",
        )

    create_chapter_footers(staging_dir / "text", metadata)
    transform_page(
        single_page_path,
        metadata,
        header_html='<header><nav><ul><li><a href="../../">Back to ebook</a></li></ul></nav></header>',
        css_hrefs=None,
        canonical_url=f"{metadata.book_url}/text/single-page" if metadata.book_url else None,
        favicon_prefix="../../",
        add_title_prefix=False,
        adjust_colophon=True,
    )


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Build downloads/ and text/ web outputs for this book."
    )
    parser.add_argument(
        "output_dir",
        help="Directory where the static output should be written.",
    )
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    script_dir = Path(__file__).resolve().parent
    source_dir = (script_dir / "..").resolve()
    output_dir = Path(args.output_dir).resolve()
    web_dir = source_dir / "src" / "web"
    web_css = source_dir / "src" / "web" / "css" / "web.css"
    web_local_css = source_dir / "src" / "web" / "css" / "web-local.css"

    if not source_dir.is_dir():
        raise RuntimeError(f"Source directory does not exist: {source_dir}")

    if not (source_dir / "src" / "epub" / "content.opf").is_file():
        raise RuntimeError(f"Not a Standard Ebooks source directory: {source_dir}")

    if not web_css.is_file():
        raise RuntimeError(f"Missing stylesheet: {web_css}")
    if not web_local_css.is_file():
        raise RuntimeError(f"Missing stylesheet: {web_local_css}")
    if not web_dir.is_dir():
        raise RuntimeError(f"Missing web assets directory: {web_dir}")

    if shutil.which("se") is None:
        raise RuntimeError("The `se` command is not installed or not on PATH.")

    with tempfile.TemporaryDirectory(prefix="build-release-") as temp_root_raw:
        staging_dir = Path(temp_root_raw) / "staging"
        downloads_dir = staging_dir / "downloads"
        run_command(
            ["se", "prepare-release", str(source_dir)],
            cwd=source_dir,
            description="Updating metadata (dates/revision/word-count)...",
        )
        metadata = parse_book_metadata(source_dir)

        downloads_dir.mkdir(parents=True, exist_ok=True)
        run_command(
            [
                "se",
                "build",
                "--check",
                "--output-dir",
                str(downloads_dir),
                "--kindle",
                "--kobo",
                str(source_dir),
            ],
            cwd=source_dir,
            description="Building ebook files...",
        )
        download_file_basename = rename_ebook_files(downloads_dir, metadata)

        build_text_output(source_dir, staging_dir, metadata, web_css, web_local_css)
        shutil.copytree(web_dir, staging_dir, dirs_exist_ok=True)
        render_landing_page(
            staging_dir / "index.html",
            metadata=metadata,
            source_dir=source_dir,
            download_file_basename=download_file_basename,
        )

        info(f"Saving output to {output_dir}")
        if output_dir.exists():
            shutil.rmtree(output_dir)
        shutil.copytree(staging_dir, output_dir)

    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except subprocess.CalledProcessError as error:
        info(f"Command failed with exit code {error.returncode}.")
        raise SystemExit(error.returncode)
    except RuntimeError as error:
        info(f"Error: {error}")
        raise SystemExit(1)
